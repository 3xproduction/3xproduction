# Minimal image for the one-shot in-VPC DB job (no frontend build → fast).
# Runs backend/scripts/db-job.js (applies migrations >=67, guarded).
FROM node:22-alpine
WORKDIR /app
COPY backend/package.json backend/package-lock.json ./backend/
RUN cd backend && npm ci --omit=dev --no-audit --no-fund
COPY backend/ ./backend/
CMD ["node", "backend/scripts/db-job.js"]
